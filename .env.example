# Токен от @BotFather
BOT_TOKEN=123456:ABC...

# Telegram user id админов через запятую (узнать: @userinfobot)
ADMIN_IDS=111111111,222222222

# Реквизиты оплаты (многострочный текст)
PAYMENT_DETAILS=USDT TRC20: TTvB9g2dtoWHb3GLduAzbqTtPXBLNs5hr4

# --- Автопроверка USDT TRC20 (по TxID через TronScan) ---
# true: после «Я оплатил» бот просит TxID и проверяет входящий USDT на ваш кошелёк.
AUTO_USDT_VERIFY_TRC20=false
# Адрес получателя в сети TRC20 (начинается с T...), должен совпадать с PAYMENT_DETAILS
TRON_USDT_RECEIVER=
# Опционально: ключ TronGrid (выше лимитов публичного API)
# TRONGRID_API_KEY=

# --- Авто-расклад через OpenAI ---
# true: после подтверждённой оплаты текст расклада генерирует модель и уходит клиенту.
AUTO_READING_AI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Для совместимых API (LM Studio, Azure и т.д.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# SQLite по умолчанию (папка data/ создаётся сама)
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

LOG_LEVEL=INFO

# --- Бесплатно «1 карта» (лимит/сутки по UTC, смотрите reading_entries) ---
ENABLE_FREE_ONE_CARD=true
FREE_CARDS_PER_DAY=1

# --- Telegram Stars (XTR) как альтернатива USDT: в @BotFather включите «Payments»/Stars при необходимости ---
# STARS_PAYMENTS=false
# STARS_TIER5=50
# STARS_TIER10=100

# Имя бота без @ — для ссылок «уточнить/новый заказ» (или подставится из getMe)
# BOT_USERNAME=YourBotName

# Скидка/промо текст (приложит к раскладу; цены в USDT/Stars настраиваются отдельно)
# UPSELL_DISCOUNT_TEXT=Скидка 30%: в комментарии к оплате напишите код SECOND7.

# Свои PNG: free.png, three1-3.png, extended.png, extended2.png (см. bot_app/assets/cards)
# CARDS_IMAGES_DIR=

# SUPPORT_USERNAME=rasklad_babushka
